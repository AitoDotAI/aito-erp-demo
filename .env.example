# Aito predictive database connection
# Get your credentials at https://aito.ai
#
# ─────────────────────────────────────────────────────────────────
# Single-tenant mode (default — one Aito DB serves the whole demo)
# ─────────────────────────────────────────────────────────────────
AITO_API_URL=https://your-instance.aito.app
AITO_API_KEY=your-api-key-here

# ─────────────────────────────────────────────────────────────────
# Multi-tenant mode (optional — one Aito DB per demo persona)
#
# When any of the per-tenant pairs below are set, the backend builds
# a separate AitoClient per persona and routes each request to the
# right DB based on the X-Tenant header sent by the frontend
# (driven by the TopBar profile switcher in the UI).
#
# Tenants that aren't configured fall back to the single-tenant
# AITO_API_URL / AITO_API_KEY above, so partial setups work too —
# you can spin up one persona at a time.
# ─────────────────────────────────────────────────────────────────

# Metsä Machinery Oy — industrial maintenance / construction
# (Lemonsoft-style buyer)
AITO_METSA_API_URL=
AITO_METSA_API_KEY=

# Aurora Retail Oy — multi-channel retail (Oscar / ERPly-style buyer)
AITO_AURORA_API_URL=
AITO_AURORA_API_KEY=

# Helsinki Studio — professional services (horizontal SaaS buyer)
AITO_STUDIO_API_URL=
AITO_STUDIO_API_KEY=

# ─────────────────────────────────────────────────────────────────
# Public-demo lockdown (set when deploying the demo to a public URL)
#
# PUBLIC_DEMO=1 enables:
#   - CORS lockdown to the origins listed in CORS_ORIGINS
#   - /api/tenants returns only ids (no raw Aito URLs)
#   - /api/schema returns 404
#   - tighter validation on submissions
#
# Rate-limit caps (per 60s window) are tunable too.
# ─────────────────────────────────────────────────────────────────
PUBLIC_DEMO=
CORS_ORIGINS=https://predictive-erp.aito.ai
RATE_LIMIT_PER_IP=60
RATE_LIMIT_PER_TENANT=600
RATE_LIMIT_GLOBAL=1500
